cluster: "katana"

attributes:
    data_warning:
        class: "d-none"
        help: |
            <div style="padding: 0.375rem 0.75rem; background-color: #E2BEBE; border: 2px solid #761313; border-radius: 0.25rem; color: #761313;">
              <span><b>Warning!</b> Please ensure your input data (e.g., FASTA file or run name) does not contain sensitive data. Katana is <b>NOT</b> suitable for sensitive or highly sensitive data. You should use the UNSW Data Classification scheme to classify your data and learn about managing your research data by visiting the <a style="color: #5B5050" href="https://research.unsw.edu.au/research-data-management-hub">Research Data Management Hub.</a></span>
            </div>

    proteinfold_version:
        widget: "select"
        label: "Proteinfold Version"
        help: |
            Choose which ProteinFold version to run.
            <ul>
                <li><b>Latest release version (2.0.0)</b> Stable release from nf-core.</li>
                <li><b>Beta version</b> Contains experimental features - Not thoroughly tested.</li>
            </ul>
        options:
            - ["Latest release (2.0.0)", "release", {data-hide-random_seed: true}]
            - ["Beta version", "dev", {data-hide-prot_mode: true}]
        display: true

    samplesheet:
        widget: "path_selector"
        label: "Input"
        pattern: "*.csv^"
        placeholder: "path/to/file(s) or sequence 'NLYIQWLKDGGPSSGRPPPS'"
        required: true
    samplesheet_help:
        class: "d-none"
        label: "Input Options"
        help: |
            • <b>Directory:</b> <code>/srv/scratch/z3141592/my_experiment/</code>
            <br>• <b>Single file:</b> <code>protein.fasta</code>, <code>protein.yaml</code>, or <code>samplesheet.csv</code>
            <br>• <b>Sequence:</b> <code>NLYIQWLKDGGPSSGRPPPS</code> or <code>NLYIQWLKDGGPSSGRPPPS:MKTVRQERLKSDHELFRTHT</code>
            <br>📖 <a href="https://unsw.sharepoint.com/sites/StructuralBiologyFacility-UserDocumentation/SitePages/ProteinFold-User-Guide.aspx?ga=1#preparing-your-inputs">User Guide</a> for advanced options.
    run_name:
        widget: "text_field"
        label: "Run Name"
        placeholder: "Enter your run name"
        pattern: '^[A-Za-z0-9_\- ]+$'
        required: true
        help: |
            <a>Alphanumeric and "_" only</a>

    af_method:
        widget: "select"
        label: "Method"
        help: |
            <ul>
                <li><b>Boltz</b> High accuracy, Faster; Open AlphaFold3 method - <a href="https://doi.org/10.1101/2024.11.19.624167">Paper-1</a> <a href="https://doi.org/10.1101/2025.06.14.659707">Paper-2</a></li>
                <li><b>AlphaFold2.3</b> High accuracy, Slower - <a href="https://doi.org/10.1038/s41586-021-03819-2">Paper</a></li>
                <li><b>AlphaFold3</b> High accuracy, Restricted use - <a href="https://doi.org/10.1038/s41586-024-07487-w">Paper</a></li>
                <li><b>ColabFold</b> High accuracy - <a href="https://doi.org/10.1038/s41592-022-01488-1">Paper</a></li>
                <li><b>ESMFold</b> Medium/Low accuracy, Fastest; No evolutionary sequence calculations - <a href="https://doi.org/10.1126/science.ade2574">Paper</a></li>
            </ul>
        options:
            - ["Boltz", "boltz", {data-hide-prot_mode: true, data-hide-full_dbs: true, data-hide-colabfold_num_recycles: true, data-hide-colabfold_advanced_options: true, data-hide-colabfold_num_seeds: true, data-hide-colabfold_use_dropout: true, data-hide-colabfold_max_msa: true, data-hide-esmfold_num_recycles: true, data-hide-af3_weights: true, data-hide-af3_warning: true}]
            - ["AlphaFold2", "alphafold2", {data-hide-colabfold_num_recycles: true, data-hide-colabfold_advanced_options: true, data-hide-colabfold_num_seeds: true, data-hide-colabfold_use_dropout: true, data-hide-colabfold_max_msa: true, data-hide-esmfold_num_recycles: true, data-hide-boltz_use_potentials: true, data-hide-af3_weights: true, data-hide-af3_warning: true}]
            - ["AlphaFold3", "alphafold3", {data-hide-prot_mode: true, data-hide-full_dbs: true, data-hide-random_seed: true, data-hide-colabfold_num_recycles: true, data-hide-colabfold_advanced_options: true, data-hide-colabfold_num_seeds: true, data-hide-colabfold_use_dropout: true, data-hide-colabfold_max_msa: true, data-hide-esmfold_num_recycles: true, data-hide-boltz_use_potentials: true}]
            - ["ColabFold", "colabfold", {data-hide-full_dbs: true, data-hide-esmfold_num_recycles: true, data-hide-boltz_use_potentials: true, data-hide-af3_weights: true, data-hide-af3_warning: true}]
            - ["ESMFold", "esmfold", {data-hide-full_dbs: true, data-hide-random_seed: true, data-hide-colabfold_num_recycles: true, data-hide-colabfold_advanced_options: true, data-hide-colabfold_num_seeds: true, data-hide-colabfold_use_dropout: true, data-hide-colabfold_max_msa: true, data-hide-boltz_use_potentials: true, data-hide-af3_weights: true, data-hide-af3_warning: true}]
        display: true

    af3_weights:
        widget: "path_selector"
        label: "AlphaFold3 Weights"
        placeholder: "Enter path to af3.bin"
        required: true

    af3_warning:
        class: "d-none"
        label: "AlphaFold3 Warning"
        help: |
            <div style="padding: 0.375rem 0.75rem; background-color: #FBEAEA; border: 2px solid #B42318; border-radius: 0.25rem; color: #7A271A;">
              <p><b>Warning:</b> Users must provide their own weights to run AlphaFold3 predictions. Weights can be requested from Google DeepMind at <a style="color: #0033A0; text-decoration: underline; font-weight: 700;" href="https://github.com/google-deepmind/alphafold3?tab=readme-ov-file#obtaining-model-parameters">this link</a> and are available for restricted use. Please consult the <a style="color: #0033A0; text-decoration: underline; font-weight: 700;" href="https://github.com/google-deepmind/alphafold3/blob/main/WEIGHTS_TERMS_OF_USE.md">terms of use</a> and check with your PI to confirm that this is suitable for your use case.</p>
              <p>AlphaFold3 can <b>NOT</b> be used for:</p>
              <ul>
                <li>Commercial projects.</li>
                <li>Training ML models.</li>
              </ul>
            </div>

    prot_mode:
        widget: "select"
        label: "Mode"
        help: |
            Please ensure that the mode matches your input data (for example, use monomer mode for monomer inputs).
        options:
            - ["Monomer_ptm", "monomer_ptm"]
            - ["Multimer", "multimer"]
        display: true

    full_dbs:
        widget: "select"
        label: "MSA Search Database"
        options:
            - ["Reduced", "reduced"]
            - ["Full", "full"]
        display: true
        help: |
            Search the full bfd database with hhblits (slower) or cluster representatives with JackHMMER (faster)
            <ul>
                <li><b>Full</b> High accuracy, slower</li>
                <li><b>Reduced</b> Optimised for speed</li>
            </ul>

    colabfold_num_recycles:
        widget: "number_field"
        label: "ColabFold Recycles"
        value: 3
        min: 1
        max: 20
        help: |
            Higher values may improve quality but increase runtime.

    colabfold_advanced_options:
        widget: "check_box"
        label: "ColabFold Conformational Sampling"
        checked_value: "yes"
        unchecked_value: "no"
        help: |
            Expose advanced ColabFold options for conformational sampling by varying seeds, dropout, and MSA depth.
            <br>📖 <a href="https://www.ebi.ac.uk/training/online/courses/alphafold/advanced-modeling-and-applications-of-predicted-protein-structures/customising-alphafold-structure-predictions/">ColabFold guide</a>
            <br>📄 Background: <a href="https://elifesciences.org/articles/75751">del Alamo et al. 2022</a>

    random_seed:
        widget: "number_field"
        label: "Random Seed"
        value: 0
        min: 0
        help: |
            Fixed seed for reproducible runs. Default is 0; set a different value to sample alternative runs.

    colabfold_max_msa:
        widget: "select"
        label: "ColabFold Max MSA"
        options:
            - ["auto", "auto"]
            - ["512:1024", "512:1024"]
            - ["256:512", "256:512"]
            - ["64:128", "64:128"]
            - ["32:64", "32:64"]
            - ["16:32", "16:32"]
        value: "auto"
        help: |
            Notebook-style MSA depth preset in the form max_seq:max_extra_seq. Lower values can increase diversity at the cost of confidence.

    colabfold_num_seeds:
        widget: "select"
        label: "ColabFold Number of Seeds"
        options:
            - ["1", "1"]
            - ["2", "2"]
            - ["4", "4"]
            - ["8", "8"]
            - ["16", "16"]
        value: "1"
        help: |
            Number of seeds to run for ColabFold sampling. Higher values increase runtime and produce more sampled conformations.

    colabfold_use_dropout:
        widget: "check_box"
        label: "ColabFold Dropout"
        checked_value: "true"
        unchecked_value: "false"
        help: |
            Enable dropout during inference to increase sampling diversity.

    esmfold_num_recycles:
        widget: "number_field"
        label: "ESMFold Recycles"
        value: 4
        min: 1
        max: 20
        help: |
            Higher values may improve quality but increase runtime.

    boltz_use_potentials:
        widget: "select"
        label: "Boltz Potentials"
        options:
            - ["Disabled", "false"]
            - ["Enabled", "true"]
        help: |
            Enable physics-based potentials to improve physical validity of predicted outputs (additional memory and runtime cost).

    save_intermediates:
        widget: "check_box"
        label: "Save Intermediate Files"
        checked_value: "true"
        unchecked_value: "false"
        help: |
                        Save intermediate prediction files and additional (non-top-ranked) results.

                        <div id="save_intermediates_warning" class="d-none" style="padding: 0.375rem 0.75rem; background-color: #E2BEBE; border: 2px solid #761313; border-radius: 0.25rem; color: #761313; margin-top:0.5rem;">
                            <span><b>Warning!</b> Enabling this can significantly increase output size especially for AlphaFold2. Ensure that your scratch storage is sufficient and consider cleaning up the files after use.</span>
                        </div>
                        <div id="save_intermediates_enforced" class="d-none" style="margin-top:0.5rem; font-style: italic; color: #5B5050;">
                            This option is enabled and locked while ColabFold conformational sampling is active.
                        </div>


    msa_server: "local"
        # widget: "select"
        # label: "MSA Server"
        # options:
        #     - ["Local", "local"]
        #     - ["Webserver", "webserver"]
        # help: |
        #     <ul>
        #         <li><b>Local</b> Use local compute resources</li>
        #         <li><b>Webserver</b> Use remote webserver</li>
        #     </ul>

    citation_request:
        label: "Facility Citation"
        class: "d-none"
        help: |
            Please include the following acknowledgement in publications that use this resource:
            <br>
            <i>"The authors acknowledge use of facilities in the Structural Biology Facility within the Mark Wainwright Analytical Centre - UNSW"</i>
            <br>
            <b>DOI:</b> <a href="https://doi.org/10.26190/4KQF-M552">10.26190/4KQF-M552</a>

    katana_citation:
        label: "Katana HPC Citation"
        class: "d-none"
        help: |
            Please include the following acknowledgement in publications that use Katana:
            <br>
            <i>"This research includes computations using the computational cluster Katana supported by Research Technology Services at UNSW Sydney."</i>
            <br>
            <b>DOI:</b> <a href="https://doi.org/10.26190/669x-a286">10.26190/669X-A286</a>
