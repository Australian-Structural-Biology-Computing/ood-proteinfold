ENV_FILE=".env"
if [ -f "$ENV_FILE" ]; then
    set -a
    . "$ENV_FILE"
    set +a
fi

RUN_DIR=$(echo "<%= context.run_name %>" | sed "s#[^A-Za-z0-9]#_#g")
BASE_OUT_DIR="${BASE_OUT_DIR:-${PFOLD_BASE_OUT_DIR:-/srv/scratch/${USER}/proteinfold_output}}"
OUT_DIR="${BASE_OUT_DIR}/${RUN_DIR}"
RESULTS_URL_BASE="${RESULTS_URL_BASE:-${OOD_RESULTS_URL_BASE:-/pun/sys/dashboard/files/fs}}"

ln -s "$OUT_DIR" 2>/dev/null || true

export base_out_dir="${BASE_OUT_DIR}"
export results_url_base="${RESULTS_URL_BASE}"
export run_dir="$RUN_DIR"
export user="${USER}"
export session_output_dir="$(pwd -P)"
