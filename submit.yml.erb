<%
unless defined?(ood_site_env_loaded)
  env_path = [File.expand_path("template/.env", Dir.pwd), File.expand_path(".env", Dir.pwd)].find { |path| File.file?(path) }
  if env_path
    File.foreach(env_path) do |line|
      stripped = line.strip
      next if stripped.empty? || stripped.start_with?("#")
      key, raw_value = line.split("=", 2)
      next if raw_value.nil?
      value = raw_value.strip
      value = value[1..-2] if (value.start_with?('"') && value.end_with?('"')) || (value.start_with?("'") && value.end_with?("'"))
      value = value.gsub(/\$\{([A-Za-z_][A-Za-z0-9_]*)\}|\$([A-Za-z_][A-Za-z0-9_]*)/) { ENV[$1 || $2].to_s }
      key = key.strip
      ENV[key] = value if ENV[key].to_s.empty?
    end
  end
  ood_site_env_loaded = true
end
%>

<%
cluster_name = ENV.fetch("OOD_CLUSTER")
queue_name = ENV.fetch("OOD_QUEUE")
script_path = ENV.fetch("PFOLD_SCRIPT_FILE")
default_native = ENV.fetch("PFOLD_NATIVE_DEFAULT")
gpu_native = ENV.fetch("PFOLD_NATIVE_GPU")

def parse_native(val)
    val.split(/\s*;\s*/).reject(&:empty?)
end

native_default_list = parse_native(default_native)
native_gpu_list = parse_native(gpu_native)

email_default = ENV["OOD_EMAIL"] || "#{ENV['USER']}#{ENV.fetch('OOD_EMAIL_DOMAIN')}"
email_selected = (defined?(email) && email && !email.strip.empty?) ? email : email_default
%>

cluster: "<%= cluster_name %>"

batch_connect:
    template: "basic"
    queue_name: "<%= queue_name %>"
    script_file: "<%= script_path %>"
    conn_params:
        - base_out_dir
        - results_url_base
        - run_dir
        - user
        - session_output_dir

script:
    native:
    # ColabFold local DBs are only available locally on certain nodes. This is an example method for catching local ColabFold runs
     <% if (af_method == "colabfold" || af_method == "boltz") && msa_server == "local" %>
        <% native_gpu_list.each do |entry| %>
         - "<%= entry %>"
        <% end %>
         - "-N <%= (run_name || 'kod_proteinfold').gsub(' ', '_') %>"
     <% else %>
        <% native_default_list.each do |entry| %>
        - "<%= entry %>"
        <% end %>
        - "-N <%= (run_name || 'kod_proteinfold').gsub(' ', '_') %>"
     <% end %>
    email:
        - "<%= email_selected %>"
    email_on_terminated: "<%= email_on_terminated %>"
